# Copy this to .env and fill in your values

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Account ID: Cloudflare dashboard → top-right corner
R2_ACCOUNT_ID=your_cloudflare_account_id
# Bucket name you created in R2
R2_BUCKET_NAME=your_bucket_name
# Create an R2 API token with Object Read & Write permissions
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$...
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_random_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
